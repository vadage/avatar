{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "avatar",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-06",
	"assets": {
		"binding": "ASSETS",
		"directory": "public",
		"not_found_handling": "404-page",
		"run_worker_first": ["/api/identicon/*"]
	},
	"workers_dev": false,
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "avatar.provided.space",
			"custom_domain": true
		}
	]
}
